# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sita_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sita_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# Server
PORT=3010
SOCKET_PORT=3011
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# CORS - comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3010
